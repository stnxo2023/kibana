{
  "extends": "@kbn/tsconfig-base/tsconfig.json",
  "compilerOptions": {
    "outDir": "target/types"
  },
  "include": ["*.ts", "common/**/*", "public/**/*", "server/**/*"],
  "kbn_references": [
    "@kbn/core",
    "@kbn/embeddable-plugin",
    "@kbn/presentation-publishing",
    "@kbn/presentation-publishing-schemas",
    "@kbn/config-schema",
    "@kbn/i18n",
    "@kbn/inference-common",
    "@kbn/inference-plugin",
    "@kbn/ui-theme",
    "@kbn/logging",
    "@kbn/sse-utils",
    "@kbn/sse-utils-server",
    "@kbn/sse-utils-client",
    "@kbn/data-plugin",
    "@kbn/esql-utils",
    "@kbn/es-query",
    "@kbn/es-types",
    "@kbn/datemath",
    "@kbn/search-types"
  ],
  "exclude": ["target/**/*"]
}
